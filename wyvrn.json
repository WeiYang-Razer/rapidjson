{
  "name": "rapidjson",
  "version": "1.1.0.2",
  "schemaVersion": 2,
  "kind": "HeaderOnlyLib",
  "description": "TODO: one-line description of rapidjson",
  "dependencies": {},
  
  "compatibility": {
    "compiler":         "exact",
    "arch":             "any",
    "compiler.version": "any",
    "compiler.cppstd":  "lte",
    "compiler.runtime": "any"
  },

  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DRAPIDJSON_BUILD_TESTS=OFF",
      "-DRAPIDJSON_BUILD_EXAMPLES=OFF",
      "-DRAPIDJSON_BUILD_DOC=OFF"
    ],
    "installDir": "install"
  }
}
